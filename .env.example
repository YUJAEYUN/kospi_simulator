# backend/ (실시간 시세 폴링 서버, 고정 IP를 가진 VM에서 상시 구동)의 주소와
# 공유 비밀키. 자세한 내용은 backend/README.md 참고.
BACKEND_URL=
BACKEND_SECRET=

# 아래 두 키는 배포된 Next.js 앱(Vercel)이 직접 호출하지 않습니다 — 로컬에서
# 유지보수 스크립트(npm run seed:kospi, npm run recalibrate)를 실행할 때만
# 필요합니다.

# 토스증권 Open API (실시간 시세) — WTS 설정 > Open API에서 발급.
# backend/.env에도 동일하게 설정해야 합니다 (배포된 백엔드가 실제로 호출하는 곳).
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# data.go.kr 일반 인증키 (Decoding 값을 그대로 사용)
# `npm run seed:kospi`로 코스피 구성종목 목록/캘리브레이션 데이터를 다시
# 생성할 때만 필요합니다.
# - 금융위원회_주식시세정보 (GetStockSecuritiesInfoService) 활용신청 필요
# - 금융위원회_지수시세정보 (GetMarketIndexInfoService) 활용신청 필요 (코스피 지수 캘리브레이션용)
DATA_GO_KR_SERVICE_KEY=

# DART(전자공시) OpenAPI — 자기주식 제외 유통주식수 조회용 (npm run seed:kospi 실행할 때만 필요)
DART_API_KEY=
